{
  "name": "marp-templates",
  "version": "2.0.0",
  "scripts": {
    "build": "node scripts/build-slides.js",
    "build:pdf": "node scripts/build-slides.js --pdf",
    "build:all": "node scripts/build-slides.js --all",
    "build:samples": "marp -I samples/ -o dist/samples/",
    "preview": "marp -s slides/",
    "preview:samples": "marp -s samples/",
    "watch": "node scripts/build-slides.js --watch",
    "sync-themes": "node scripts/sync-themes.js",
    "archive": "node scripts/archive-slides.js"
  }
}
